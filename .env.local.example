# Sanity.io (https://www.sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API Token (нужен только для webhook revalidation)
